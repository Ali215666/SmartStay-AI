{
  "info": {
    "name": "SmartStay AI - Assignment 1",
    "description": "REST and WebSocket checks for the local conversational system.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "wsUrl", "value": "ws://localhost:8000/ws/chat" }
  ],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" }
    },
    {
      "name": "Chat",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"What time is check-in?\"\n}"
        },
        "url": "{{baseUrl}}/api/chat"
      }
    },
    {
      "name": "Streaming Chat",
      "request": {
        "method": "GET",
        "url": "{{wsUrl}}",
        "description": "Open as a WebSocket request and send: {\"session_id\":\"postman-demo\",\"message\":\"I need a Deluxe room\"}"
      }
    }
  ]
}

